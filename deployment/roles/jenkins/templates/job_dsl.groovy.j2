/* INITIALIZATION JOBS */
freeStyleJob('Init EIP repository') {
    description('Initializes the EIP repository with the necessary files for the pipeline.')
    steps {
        shell('''
            #!/bin/bash
            set -e

            clone_or_pull() {
                local repo="$1"
                local dest="$2"
                if [ -d "$dest/.git" ]; then
                    git -C "$dest" pull origin main
                else
                    rm -rf "$dest"
                    git clone "$repo" "$dest"
                fi
            }

            clone_or_pull "{{ epitech_repository_url }}" "{{ tili_dir }}"
            clone_or_pull "{{ backend_repository_url }}" "{{ tili_dir }}/backend"
            clone_or_pull "{{ webapp_repository_url }}" "{{ tili_dir }}/webapp"
            clone_or_pull "{{ mobile_repository_url }}" "{{ tili_dir }}/mobile"
        ''')
    }
}



/* IMAGES JOBS */
folder('Images') {
    description('Folder for Docker images')
}

freeStyleJob('Images/Flutter') {
    description('Builds the Flutter base image.')
    steps {
        shell('''
            docker build -t flutter-tili - < {{ jenkins_home }}/images/flutter/Dockerfile
        ''')
    }
}

freeStyleJob('Images/Javascript') {
    description('Builds the Javascript base image.')
    steps {
        shell('''
            docker build -t javascript-tili - < {{ jenkins_home }}/images/javascript/Dockerfile
        ''')
    }
}

freeStyleJob('Images/Go') {
    description('Builds the Go base image.')
    steps {
        shell('''
            docker build -t go-tili - < {{ jenkins_home }}/images/go/Dockerfile
        ''')
    }
}



/* EIP JOBS */
folder('Tili') {
    description('Folder for EIP pipeline jobs')
}

freeStyleJob('Tili/Push to production') {
    description('Pushes the EIP repository to production.')
    triggers {
        scm('H/5 * * * *')
    }
    steps {
        shell('''
          set -e
          cd {{ tili_dir }}

          git config user.email "jenkins@jenkins.local"
          git config user.name "Jenkins"

          git -C backend pull origin main
          git -C webapp pull origin main
          git -C mobile pull origin main
          rm -rf backend/.git webapp/.git mobile/.git

          git rm --cached backend webapp mobile 2>/dev/null || true

          git pull origin main
          git add backend webapp mobile
          git diff --cached --quiet || git commit -m "Automated commit from Jenkins"
          git push origin main

          git clone {{ backend_repository_url }} /tmp/backend_restore
          mv /tmp/backend_restore/.git backend/.git
          rm -rf /tmp/backend_restore

          git clone {{ webapp_repository_url }} /tmp/webapp_restore
          mv /tmp/webapp_restore/.git webapp/.git
          rm -rf /tmp/webapp_restore

          git clone {{ mobile_repository_url }} /tmp/mobile_restore
          mv /tmp/mobile_restore/.git mobile/.git
          rm -rf /tmp/mobile_restore
        ''')
    }
}

freeStyleJob('Tili/Run Go Backend') {
    description('Runs the Go backend using the go-tili image.')
    steps {
        shell('''
            # Stop and remove any existing backend container
            docker stop go-backend-container || true
            docker rm go-backend-container || true

            # Run the Go backend in background
            docker run --name go-backend-container -p 8081:8081 -v {{ tili_dir }}/backend:/app go-tili
            echo "Go backend is running on port 8081 with container name 'go-backend-container'"
            echo "To stop the backend, run: docker stop go-backend-container"
        ''')
    }
}
